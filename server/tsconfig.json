{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "declaration": false,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts", "seed.ts", "scripts/**/*.ts"]
}
